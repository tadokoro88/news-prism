# Bedrock APAC CRIS のモデル ID (必須)
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-6
AWS_REGION=ap-northeast-1
# 個人化 context.md を fetch する URL (任意、未設定なら 3 視点解析だけ動く)
# 例: https://raw.githubusercontent.com/<account>/<private-repo>/refs/heads/main/context.md
# 取得方法 / context.md のスキーマは README の「個人化機能」を参照
NEWS_PRISM_CONTEXT_URL=
# 上記 URL が private repo の場合のみ
NEWS_PRISM_GH_PAT=
# 企業 MITM プロキシ環境の場合
# SSL_CERT_FILE=/path/to/ca-bundle.pem